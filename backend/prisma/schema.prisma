generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  owner
  approver
  reader
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  role         UserRole @default(reader)
  passwordHash String
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvalWorkflowSteps ApprovalWorkflowStep[]
  documentGrants        DocumentAccess[]
}

model Document {
  id            String   @id @default(uuid())
  code          String   @unique
  title         String
  description   String
  category      String
  standardTags  String[]
  status        String   @default("draft")
  ownerId       String
  visibility    String   @default("internal")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  obsoleteReason String?

  currentVersionId String

  versions  DocumentVersion[]
  approvals DocumentApproval[]
  signatures String[]
  grants DocumentAccess[]
}

model DocumentAccess {
  id        String   @id @default(uuid())
  userId    String
  grantedBy String
  createdAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
}

model DocumentVersion {
  id            String   @id @default(uuid())
  number        Int
  title         String
  content       String
  createdAt     DateTime @default(now())
  createdBy     String
  changeSummary String

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model DocumentApproval {
  id         String    @id @default(uuid())
  approverId String
  stepOrder  Int?
  responsibility String?
  status     String    @default("pending")
  comment    String?
  decidedAt  DateTime?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@unique([documentId, approverId])
}

model AuditEvent {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  actorId    String
  action     String
  entityType String
  entityId   String
  details    Json

  @@index([entityId])
  @@index([entityType])
}

model ApprovalWorkflow {
  id        String   @id @default(uuid())
  category  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps ApprovalWorkflowStep[]
}

model ApprovalWorkflowStep {
  id             String           @id @default(uuid())
  stepOrder      Int
  responsibility String
  createdAt      DateTime         @default(now())

  workflowId String
  workflow   ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  approverId String
  approver   User   @relation(fields: [approverId], references: [id], onDelete: Restrict)

  @@index([workflowId])
  @@unique([workflowId, stepOrder])
  @@unique([workflowId, approverId])
}
