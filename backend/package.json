    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.3",
